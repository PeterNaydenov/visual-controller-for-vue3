{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "declaration": true,
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": false,
    "moduleResolution": "bundler",
    "paths": {
      "ask-for-promise": ["./node_modules/ask-for-promise/types.d.ts"],
      "vue": ["./node_modules/vue/dist/vue.d.ts"]
    }
  },
  "include": ["src/main.js"]
}