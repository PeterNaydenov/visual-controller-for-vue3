{
  "name": "@peter.naydenov/visual-controller-for-vue3",
  "description": "Use it when single javascript application should control multiple vue3 apps.",
  "version": "2.2.1",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "./src/main.js",
  "types": "./dist/main.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/visual-controller-for-vue3.esm.mjs",
      "require": "./dist/visual-controller-for-vue3.cjs",
      "default": "./dist/visual-controller-for-vue3.umd.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run types",
    "preview": "vite preview",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "types": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterNaydenov/visual-controller-for-vue3.git"
  },
  "dependencies": {
    "ask-for-promise": "^3.1.0"
  },
  "devDependencies": {
    "@peter.naydenov/notice": "^2.4.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "vue": "^3.5.32"
  }
}
