{
  "name": "@peter.naydenov/visual-controller-for-vue3",
  "description": "Use it when single javascript application should control multiple vue3 apps.",
  "version": "2.1.7",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "./dist/visual-controller-for-vue3.umd.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/visual-controller-for-vue3.esm.mjs",
      "require": "./dist/visual-controller-for-vue3.cjs",
      "default": "./dist/visual-controller-for-vue3.umd.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "rollup -c",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterNaydenov/visual-controller-for-vue3.git"
  },
  "dependencies": {
    "ask-for-promise": "^3.1.0"
  },
  "devDependencies": {
    "@peter.naydenov/notice": "^2.4.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.2",
    "rollup": "^4.60.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue": "^3.5.32"
  }
}